# استخدم هذا الملف عندما البورت 80 محجوز
# شهادة ذاتية (المتصفح قد يحذّر) - Let's Encrypt لا يعمل بدون البورت 80

:443 {
    tls internal
    handle /driver* {
        uri strip_prefix /driver
        reverse_proxy driver-web:3001
    }
    handle /employee* {
        uri strip_prefix /employee
        reverse_proxy employee-web:3002
    }
    handle {
        reverse_proxy app:3000
    }
}
