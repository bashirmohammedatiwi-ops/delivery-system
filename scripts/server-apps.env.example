# مسارات المشاريع على السيرفر — انسخ إلى server-apps.env
# cp scripts/server-apps.env.example scripts/server-apps.env

DELIVERY_ROOT=/opt/delivery-system
PRICE_APP_ROOT=/opt/price_app
RYBELLA_ROOT=/opt/ry

# دومينات
DELIVERY_DOMAIN=demaalhayaadelivery.online
RYBELLA_DOMAIN=rybellairaq.com
RYBELLA_ADMIN_DOMAIN=admin.rybellairaq.com

SSL_EMAIL=admin@demaalhayaadelivery.online

# منافذ داخلية (localhost فقط)
DELIVERY_PORT=3000
PRICE_API_PORT=5000
PRICE_ADMIN_PORT=5001
PRICE_CLIENT_PORT=5002
RYBELLA_ADMIN_PORT=4000
RYBELLA_STORE_PORT=4003

# true = nginx Ubuntu يدير 80/443 (موصى به لسيرفر متعدد المواقع)
MULTISITE=true
