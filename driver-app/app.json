{
  "expo": {
    "name": "تطبيق السائق - ديما الحياة",
    "slug": "delivery-driver-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "delivery-driver",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alhayat.deliverydriver",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "NSCameraUsageDescription": "السماح بالوصول للكاميرا لمسح الباركود"
      }
    },
    "android": {
      "package": "com.alhayat.deliverydriver",
      "usesCleartextTraffic": true,
      "permissions": ["android.permission.CAMERA"]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "السماح بالوصول للكاميرا لمسح الباركود"
        }
      ]
    ]
  }
}
