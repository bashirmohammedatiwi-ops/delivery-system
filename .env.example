# شركة ديما الحياة - إعدادات النشر
# انسخ هذا الملف إلى .env وعدّل القيم حسب الحاجة

NODE_ENV=production
PORT=3000
EMPLOYEE_PORT=3002
DRIVER_PORT=3001

# عند التشغيل داخل Docker - اسم خدمة التطبيق الرئيسي
MAIN_HOST=app
MAIN_PORT=3000

# للـ HTTPS على السيرفر: عيّن دومينك (مثال: demaalhayaadelivery.online)
# شغّل: bash scripts/init-ssl.sh للحصول على شهادة Let's Encrypt
DOMAIN=demaalhayaadelivery.online
SSL_EMAIL=admin@demaalhayaadelivery.online
