# شركة ديما الحياة - إعدادات النشر
# انسخ هذا الملف إلى .env وعدّل القيم حسب الحاجة

NODE_ENV=production
PORT=3000
EMPLOYEE_PORT=3002
DRIVER_PORT=3001

# عند التشغيل داخل Docker - اسم خدمة التطبيق الرئيسي
MAIN_HOST=app
MAIN_PORT=3000

# للـ HTTPS على السيرفر: عيّن دومينك (مثال: delivery.company.com)
# Caddy يحصل على شهادة Let's Encrypt تلقائياً
# DOMAIN=delivery.your-domain.com
