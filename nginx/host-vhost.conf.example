# مثال: nginx على النظام (Ubuntu) — دومين التوصيل فقط
# انسخ إلى: /etc/nginx/sites-available/demaalhayaadelivery.online
# ثم: ln -s ... sites-enabled/ && nginx -t && systemctl reload nginx
#
# Docker nginx يعمل على localhost:8080 (HTTP) بفضل override-multisite.yml

server {
    listen 80;
    server_name demaalhayaadelivery.online www.demaalhayaadelivery.online;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name demaalhayaadelivery.online www.demaalhayaadelivery.online;

    ssl_certificate     /etc/letsencrypt/live/demaalhayaadelivery.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/demaalhayaadelivery.online/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 120s;
        proxy_read_timeout 120s;
    }
}
