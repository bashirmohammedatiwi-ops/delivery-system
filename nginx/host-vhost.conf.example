# nginx النظام — demaalhayaadelivery.online
# /price/ → تطبيق منفصل | / → نظام التوصيل على :3000
#
#   sudo cp nginx/host-vhost.conf.example /etc/nginx/sites-available/demaalhayaadelivery.online
#   sudo ln -sf /etc/nginx/sites-available/demaalhayaadelivery.online /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# عدّل PRICE_PORT (5000) حسب منفذ تطبيق /price/ على سيرفرك

upstream price_app {
    server 127.0.0.1:5000;
    keepalive 8;
}

upstream delivery_app {
    server 127.0.0.1:3000;
    keepalive 8;
}

server {
    listen 80;
    server_name demaalhayaadelivery.online www.demaalhayaadelivery.online;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name demaalhayaadelivery.online www.demaalhayaadelivery.online;

    ssl_certificate     /etc/letsencrypt/live/demaalhayaadelivery.online/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/demaalhayaadelivery.online/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location /price/ {
        proxy_pass http://price_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 120s;
        proxy_read_timeout 120s;
    }

    location = /price {
        return 301 /price/;
    }

    location /driver/ {
        proxy_pass http://delivery_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /employee/ {
        proxy_pass http://delivery_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        proxy_pass http://delivery_app;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_connect_timeout 120s;
        proxy_read_timeout 120s;
    }
}
